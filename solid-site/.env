# my.dw.com — committed default environment.
#
# Override locally with .env.local (gitignored).
# Override in CI via GitHub Actions workflow env block.

# Base URL for DW GraphQL content queries.
#
# Today: webapi.dw.com's CORS preflight is broken for browser-side calls
#        (see handoff/architecture-risks.md R8). Until DW widens the CORS
#        headers, we route through the small Cloudflare Worker in
#        ../cloudflare-worker/.
#
# Set this to:
#   - Your Worker URL (e.g. https://mydw-gw.<handle>.workers.dev) while the
#     direct endpoint is blocked.
#   - https://webapi.dw.com/graphql once DW's gateway returns proper
#     Access-Control-Allow-Methods / Allow-Headers.
#
# The placeholder below is intentionally invalid so we fail loud if it
# wasn't overridden.
VITE_GRAPHQL_BASE_URL=https://mydw-api.impalatab.workers.dev
